# PostgreSQL connection (VPS — existing Postgres container on siyada-orchestrator_default network)
# In Docker: hostname is 'db' (the Postgres service name in siyada-orchestrator)
# Local dev: use localhost or your local Postgres
DATABASE_URL=postgres://journals_user:PASSWORD@db:5432/journals

# Paperclip API
PAPERCLIP_API_URL=http://localhost:3100
PAPERCLIP_API_KEY=your-paperclip-api-key
PAPERCLIP_COMPANY_ID=your-company-id

# JWT secret for auth (Phase 3) — generate with: openssl rand -hex 32
JWT_SECRET=

# Server port (docker-compose sets this to 3200)
PORT=3200
